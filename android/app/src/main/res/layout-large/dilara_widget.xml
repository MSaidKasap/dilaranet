<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:clipToOutline="true"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Konum ve ikon -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_location_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginRight="6dp"
            android:src="@android:drawable/ic_menu_mylocation"
            android:tint="#FFD600" />

        <TextView
            android:id="@+id/widget_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Isparta Merkez"
            android:textColor="#FFEB3B"
            android:textSize="22sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_next_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:text="SIRADAKİ"
        android:textColor="#B0B0B0"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/widget_next_prayer_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:fontFamily="sans-serif-medium"
        android:text="Öğle"
        android:textColor="#FFD600"
        android:textSize="32sp" />

    <TextView
        android:id="@+id/widget_next_prayer_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-2dp"
        android:fontFamily="sans-serif-black"
        android:text="13:16"
        android:textColor="#FFFFFF"
        android:textSize="56sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#222222"
        android:clipToOutline="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingTop="6dp"
        android:paddingRight="16dp"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/widget_remaining_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginRight="6dp"
            android:src="@android:drawable/ic_lock_idle_alarm"
            android:tint="#FFD600" />

        <TextView
            android:id="@+id/widget_remaining_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="01 s 20 dk"
            android:textColor="#FFD600"
            android:textSize="24sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_sunset_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView11"
            android:layout_width="32dp"
            android:layout_height="26dp"
            android:layout_weight="1"
            android:src="@drawable/sunset" />

        <TextView
            android:id="@+id/widget_sunset_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="12dp"
            android:fontFamily="sans-serif-medium"
            android:text="Akşam"
            android:textColor="#FFA726"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/widget_sunset_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="18:50"
            android:textColor="#FFA726"
            android:textSize="24sp" />
    </LinearLayout>

    <!-- Backward compatibility: next2 label/time (gizli) -->
    <TextView
        android:id="@+id/widget_next2_label"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_next2_time"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />
</LinearLayout>
