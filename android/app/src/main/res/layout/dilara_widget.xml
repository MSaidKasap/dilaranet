<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:clipToOutline="true"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Konum ve ikon -->

    <!-- SIRADAKİ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_location_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginRight="4dp"
            android:src="@android:drawable/ic_menu_mylocation"
            android:tint="#FFD600" />

        <TextView
            android:id="@+id/widget_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Isparta Merkez"
            android:textColor="#FFEB3B"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_next_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:text="SIRADAKİ"
        android:textColor="#B0B0B0"
        android:textSize="12sp" />

    <!-- Sonraki vakit adı -->
    <TextView
        android:id="@+id/widget_next_prayer_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-2dp"
        android:fontFamily="sans-serif-medium"
        android:text="Öğle"
        android:textColor="#FFD600"
        android:textSize="22sp" />

    <!-- Sonraki vakit saati -->


    <!-- Kalan süre -->
    <TextView
        android:id="@+id/widget_next_prayer_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-4dp"
        android:fontFamily="sans-serif-black"
        android:text="13:16"
        android:textColor="#FFFFFF"
        android:textSize="36sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginLeft="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginRight="0dp"
        android:layout_marginBottom="4dp"
        android:background="#222222"
        android:clipToOutline="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="10dp"
        android:paddingTop="4dp"
        android:paddingRight="10dp"
        android:paddingBottom="4dp">

        <ImageView
            android:id="@+id/widget_remaining_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginRight="4dp"
            android:src="@android:drawable/ic_lock_idle_alarm"
            android:tint="#FFD600" />

        <TextView
            android:id="@+id/widget_remaining_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="01 s 20 dk"
            android:textColor="#FFD600"
            android:textSize="16sp" />
    </LinearLayout>


    <!-- Kalan sürenin altında, ortada: gün batımı ikonu + Akşam + saat -->
    <LinearLayout
        android:id="@+id/widget_sunset_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView11"
            android:layout_width="27dp"
            android:layout_height="22dp"
            android:layout_weight="1"
            android:src="@drawable/sunset" />

        <TextView
            android:id="@+id/widget_sunset_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="Akşam"
            android:textColor="#FFA726"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/widget_sunset_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="18:50"
            android:textColor="#FFA726"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Alt satır: bir sonraki vakit ve saat -->


    <!-- Backward compatibility: next2 label/time (gizli) -->
    <TextView
        android:id="@+id/widget_next2_label"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_next2_time"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />
</LinearLayout>
